{
  "expo": {
    "name": "Sovereign Sol",
    "slug": "lycheetah-mobile",
    "version": "5.56.0",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "dark",
    "newArchEnabled": true,
    "updates": {
      "enabled": false
    },
    "scheme": "lycheetah",
    "splash": {
      "image": "./assets/splash-icon.png",
      "resizeMode": "contain",
      "backgroundColor": "#0A0A0A"
    },
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.lycheetah.sol"
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/adaptive-icon.png",
        "backgroundColor": "#0A0A0A"
      },
      "package": "com.lycheetah.sol",
      "versionCode": 10,
      "permissions": []
    },
    "web": {
      "favicon": "./assets/favicon.png"
    },
    "plugins": [
      [
        "expo-notifications",
        {
          "icon": "./assets/icon.png",
          "color": "#F5A623",
          "defaultChannel": "cognitive-weather"
        }
      ]
    ],
    "extra": {
      "eas": {
        "projectId": "55350e14-5cdc-4a5f-8a0e-735bca572dd3"
      }
    },
    "owner": "solveyra"
  }
}
